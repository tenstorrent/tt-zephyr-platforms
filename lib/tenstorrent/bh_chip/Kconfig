config TT_BH_CHIP
	bool "Use the high level bh_chip abstraction"
	depends on JTAG
	depends on GPIO
	help
		Enable the high level bh_chip abstraction

if TT_BH_CHIP

config TT_I2C_STRAP_INIT_PRIORITY
	int "Initialization priority for I2C strapping"
	default 40
	help
	  Priority for I2C strap initialization. This should be set
	  to initialize before the I2C bus, so that GPIO expanders used
	  for strapping can be properly configured during system boot

module = TT_BH_CHIP
module-str = BH Chip API
source "subsys/logging/Kconfig.template.log_config"

endif # TT_BH_CHIP
