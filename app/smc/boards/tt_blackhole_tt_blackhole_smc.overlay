/ {
	chosen {
		zephyr,console = &vuart0;
		zephyr,shell-uart = &vuart0;
	};

	vuart0: uart_tt_virt {
		compatible = "tenstorrent,vuart";
		version = <0x00000000>;
		status = "disabled";
	};
};

&vuart0 {
	status = "okay";
};

&i2c1 {
	status = "disabled";
};

&i2c2 {
	status = "disabled";
};
