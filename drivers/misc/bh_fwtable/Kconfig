config BH_FWTABLE
	bool "Tenstorrent Blackhole Firmware Table"
	default y
	depends on DT_HAS_TENSTORRENT_BH_FWTABLE_ENABLED
	depends on TT_BOOT_FS
	help
		Enable the Tenstorrent Blackhole Firmware Table.

if BH_FWTABLE

module = BH_FWTABLE
module-str = bh_fwtable
source "subsys/logging/Kconfig.template.log_config"

config BH_FWTABLE_INIT_PRIORITY
    int "Tenstorrent Blackhole firmware table init priority"
    # The default priority must be later than the EEPROM driver (8).
    default 81
    help
      Specify the initialization priority for the FW Table driver.
      Set to a value higher than the SPI/EEPROM driver.

endif
