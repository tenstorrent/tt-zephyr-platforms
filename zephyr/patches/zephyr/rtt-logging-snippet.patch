--- /dev/null
+++ b/snippets/rtt-logging/rtt-logging.conf
@@ -0,0 +1,4 @@
+CONFIG_USE_SEGGER_RTT=y
+
+CONFIG_LOG=y
+CONFIG_LOG_BACKEND_RTT=y
