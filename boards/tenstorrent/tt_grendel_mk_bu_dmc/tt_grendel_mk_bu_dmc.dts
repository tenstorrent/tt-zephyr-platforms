/dts-v1/;
#include <st/u3/stm32u385Xg.dtsi>
#include <st/u3/stm32u385rgtxq-pinctrl.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "Tenstorrent Grendel MK BU Device Management Controller";
	compatible = "tenstorrent,tt-grendel-mk-bu-dmc";

	chosen {
		zephyr,console = &uart4;
		zephyr,flash = &flash0;
		zephyr,shell-uart = &uart4;
		zephyr,sram = &sram0;
	};

};

&flash0 {
};


&clk_hsi {
	status = "okay";
};

&clk_hsi48 {
	status = "okay";
};

&clk_lse {
	status = "okay";
};

&clk_msik {
	status = "okay";
};

&clk_msis {
	status = "okay";
	msi-pll-mode;
	msi-range = <0>; /* 96MHz (reset value) */
};

&rcc {
	clocks = <&clk_msis>;
	clock-frequency = <DT_FREQ_M(96)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <1>;
	apb2-prescaler = <1>;
	apb3-prescaler = <1>;
};

&clk_lsi {
	status = "okay";
};

&uart4 {
	pinctrl-0 = <&uart4_tx_pa0 &uart4_rx_pa1>;
	pinctrl-names = "default";
	current-speed = <115200>;
	status = "okay";
};


&i2c1 {
	pinctrl-0 = <&i2c1_scl_pb8 &i2c1_sda_pb7>;
	pinctrl-names = "default";
	status = "okay";
};

&i2c2 {
	pinctrl-0 = <&i2c2_scl_pb10 &i2c2_sda_pb14>;
	pinctrl-names = "default";
	status = "okay";
};

&i2c3 {
	pinctrl-0 = <&i2c3_scl_pa7 &i2c3_sda_pb4>;
	pinctrl-names = "default";
	status = "okay";
};

&rng {
	clocks = <&rcc STM32_CLOCK(AHB2, 18)>,
		 <&rcc STM32_SRC_MSIK RNG_SEL(1)>;
	status = "okay";
};

&spi2 {
	pinctrl-0 = <&spi2_sck_pa9 &spi2_miso_pc2
		     &spi2_mosi_pc3>;
	pinctrl-names = "default";
	status = "okay";
	cs-gpios = <&gpiob 9 GPIO_ACTIVE_LOW>, <&gpioc 9 GPIO_ACTIVE_LOW>;

	mt35xu512: mt35xu512@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <DT_FREQ_M(48)>;
		status = "okay";
		size = <0x20000000>;  /* 512 Mb (megabits) */
	};

	max7221: max7221@0 {
		compatible = "maxim,max7219";
		reg = <1>;
		spi-max-frequency = <1000000>;
		num-cascading = <1>;
		intensity = <8>;
		scan-limit = <7>;
	};
};

&iwdg {
	status = "okay";
};

&wwdg {
	status = "okay";
};

zephyr_udc0: &usb {
	pinctrl-0 = <&usb_dm_pa11 &usb_dp_pa12>;
	pinctrl-names = "default";
	status = "okay";
};
