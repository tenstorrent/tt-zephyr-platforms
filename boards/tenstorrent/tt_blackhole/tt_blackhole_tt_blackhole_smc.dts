/dts-v1/;

#include <arc/tenstorrent/tt_blackhole_smc.dtsi>
#include "tt_blackhole-pinctrl.dtsi"

#include <freq.h>

/ {
	model = "Tenstorrent Blackhole board";
	compatible = "tenstorrent,blackhole";

	chosen {
		zephyr,sram = &csm;
		zephyr,console = &uart0;
		zephyr,shell-uart = &uart0;
	};

	refclk_ttbh: refclk {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <1000000000>;
		label = "REFCLK_TTBH";
		status = "okay";
	};

	pll0: pll@80020100 {
		compatible = "tenstorrent,bh-pll";

		pll-stride = <0x100>;

		reg = <0x80020100 0x100>;

		refdiv = <2>;
		fbdiv = <128>;
		
		ctrl-bus1 = <0x18>;
		ctrl-bus5 = <1>;

		postdiv0 = <3>;
		postdiv1 = <0>;
		postdiv2 = <0>;
		postdiv3 = <0>;
		
		use-postdiv = <0xF>;

		status = "okay";
	};

	pll1: pll@80020200 {
		compatible = "tenstorrent,bh-pll";
		
		pll-stride = <0x100>;

		reg = <0x80020200 0x100>;

		refdiv = <2>;
		fbdiv = <192>;

		ctrl-bus1 = <0x18>;
		ctrl-bus5 = <1>;

		postdiv0 = <5>;
		postdiv1 = <4>;
		postdiv2 = <23>;
		postdiv3 = <0>;

		use-postdiv = <0xF>;
		
		status = "okay";
	};

	pll2: pll@80020300 {
		compatible = "tenstorrent,bh-pll";

		pll-stride = <0x100>;

		reg = <0x80020300 0x100>;

		refdiv = <2>;
		fbdiv = <68>;

		ctrl-bus1 = <0x18>;
		ctrl-bus5 = <1>;

		postdiv0 = <1>;
		postdiv1 = <0>;
		postdiv2 = <0>;
		postdiv3 = <0>;

		use-postdiv = <0xF>;
		
		status = "okay";
	};

	pll3: pll@80020400 {
		compatible = "tenstorrent,bh-pll";
		
		pll-stride = <0x100>;

		reg = <0x80020400 0x100>;

		refdiv = <2>;
		fbdiv = <120>;

		ctrl-bus1 = <0x18>;
		ctrl-bus5 = <1>;

		postdiv0 = <3>;
		postdiv1 = <0>;
		postdiv2 = <0>;
		postdiv3 = <0>;

		use-postdiv = <0xF>;
		
		status = "okay";
	};

	pll4: pll@80020500 {
		compatible = "tenstorrent,bh-pll";
		
		pll-stride = <0x100>;

		reg = <0x80020500 0x100>;

		refdiv = <2>;
		fbdiv = <64>;

		ctrl-bus1 = <0x18>;
		ctrl-bus5 = <1>;

		postdiv0 = <1>;
		postdiv1 = <1>;
		postdiv2 = <1>;
		postdiv3 = <1>;

		use-postdiv = <0xF>;
		
		status = "okay";
	};
};

&spi0 {
	status = "okay";

	spi_flash: eeprom@0 {
		compatible = "jedec,mspi-nor";
		reg = <0>;
		status = "okay";
		/* Programming has experimentally been reliable up to 17 MHz, use 15 to be safe */
		mspi-max-frequency = <DT_FREQ_M(15)>;
		mspi-io-mode = "MSPI_IO_MODE_SINGLE";
		mspi-endian = "MSPI_BIG_ENDIAN";
		quad-enable-requirements = "NONE";
	};
};

&i2c0 {
	status = "okay";
};

&i2c1 {
	status = "disabled";
};

&i2c2 {
	status = "disabled";

	fanctl0: max6639@58 {
		compatible = "maxim,max6639";
		reg = <0x58>;
		status = "disabled";
	};

	sw0: switch@72 {
		compatible = "ti,tps22993";
		reg = <0x72>;
		status = "disabled";
	};

	sw1: switch@73 {
		compatible = "ti,tps22993";
		reg = <0x73>;
		status = "disabled";
	};
};
